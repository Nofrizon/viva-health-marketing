# ============================================================
# Environment Variables Configuration for Viva Health Marketing
# ============================================================
# 
# ⚠️  IMPORTANT — Deployment (Vercel):
#   .env.local works ONLY for local development.
#   Untuk deployment online, environment variables WAJIB
#   diset melalui Vercel Dashboard:
#     Project → Settings → Environment Variables
#   Atau gunakan Vercel CLI:
#     vercel env add SUMOPOD_API_KEY
#     vercel env add SUMOPOD_BASE_URL
#     vercel env add SERPAPI_KEY
#
# 👉 Copy file ini ke .env.local dan isi nilainya:
#     cp .env.example .env.local
# ============================================================

## Required for Production

# SerpAPI - Google Maps & Reviews Scraping
# Get from: https://serpapi.com/dashboard
SERPAPI_KEY=your_serpapi_key_here

# SumoPod AI - Large Language Model API (OpenAI-compatible)
# Get from: https://ai.sumopod.com
SUMOPOD_API_KEY=your_sumopod_api_key_here
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1

# Supabase Database
# Get from: https://app.supabase.com/projects
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: Node Environment
NODE_ENV=production
